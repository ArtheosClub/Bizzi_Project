# Bizzi Platform backend — test environment.
# Loaded by the test suite (backend/tests/conftest.py). Safe to commit:
# fixed, non-sensitive values matching docker-compose.yml's postgres-test
# service (port 5433, bizzi_test db). Never put a real secret here — this
# file is committed.
#
# In CI, the "backend" job's own postgres service container runs on a
# different port (5432, matching the plain dev DATABASE_URL) and sets
# DATABASE_URL directly via the job's `env:` block — that real environment
# variable takes precedence over this file (load_dotenv never overrides an
# already-set variable by default), so this file only takes effect for a
# genuinely local `pytest` run, not in CI.

ENV=test
PORT=8000

POSTGRES_USER=bizzi
POSTGRES_PASSWORD=bizzi
POSTGRES_DB=bizzi_test
POSTGRES_TEST_DB=bizzi_test

DATABASE_URL=postgresql+psycopg://bizzi:bizzi@localhost:5433/bizzi_test
