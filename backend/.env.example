# Bizzi Platform backend — local environment template.
# Copy to .env and fill in real values for local development.
# Never commit a real .env file (see .gitignore) or a raw secret in this file.
#
# Populated incrementally as Gate B introduces each concern:
# - DATABASE_URL, POSTGRES_*: step 3 (PostgreSQL + Docker Compose)
# - ENV, PORT: step 4 (configuration module)

# Step 3: PostgreSQL + Docker Compose
# Credentials below are local-dev-only defaults (docker-compose.yml uses
# the same defaults) — never use these values outside local development.
POSTGRES_USER=bizzi
POSTGRES_PASSWORD=bizzi
POSTGRES_DB=bizzi_dev
POSTGRES_TEST_DB=bizzi_test

# Used by the app (from step 4 onward) to connect to the dev Postgres
# instance started by docker-compose.yml. Scheme is postgresql+psycopg
# (psycopg v3, not psycopg2 — see docs/planning/TECH_STACK.md).
DATABASE_URL=postgresql+psycopg://bizzi:bizzi@localhost:5432/bizzi_dev

# Step 4: configuration module. ENV is informational (logged at startup,
# not yet used to branch behavior). PORT is what uvicorn binds to.
ENV=development
PORT=8000
