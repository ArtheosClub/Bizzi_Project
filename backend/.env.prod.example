# Bizzi Platform backend — production environment TEMPLATE.
#
# This is a template only. A real .env.prod is gitignored and must never be
# committed (see backend/.gitignore) — production does not read a checked-in
# dotenv file at deploy time in the general case. Real secrets should come
# from the deployment platform's own secret injection (Docker secrets,
# Kubernetes secrets, a managed secrets store, etc.). This file exists so
# the required variable set is documented in one place, the way
# .env.example documents it for local dev.
#
# If you do use a real .env.prod locally (e.g. to test a prod-shaped
# container), copy this file to .env.prod and fill in real values there —
# never here.

ENV=production
PORT=8000

# Real production database credentials — never the dev/test defaults used
# in .env.example / .env.test.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Scheme is postgresql+psycopg (psycopg v3 — see docs/planning/TECH_STACK.md).
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<db>
